# Environment
ENVIRONMENT=development
DEBUG=true

# LLM (Ollama)
LLM_PROVIDER=ollama
LLM_MODEL_NAME=llama3.2:3b-instruct-fp16
LLM_TEMPERATURE=0.0
LLM_OLLAMA_URL=http://localhost:11434

# Embeddings
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSIONS=1024

# Retrieval
RETRIEVAL_CHILD_CHUNK_SIZE=256
RETRIEVAL_PARENT_CHUNK_SIZE=1024
RETRIEVAL_CHUNK_OVERLAP=32
RETRIEVAL_TOP_K=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.5
RETRIEVAL_ENABLE_RERANKING=true
RETRIEVAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Vector Store
VECTOR_PROVIDER=faiss
VECTOR_DB_PATH=db/db_01

# Features
ENABLE_WEB_SEARCH=false
ENABLE_SELF_CORRECTION=true

# Monitoring
MONITORING_LOG_LEVEL=INFO
MONITORING_LOG_FORMAT=text
